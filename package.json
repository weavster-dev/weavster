{
  "name": "weavster",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=20.0"
  },
  "scripts": {
    "docs:start": "pnpm --filter website start",
    "docs:build": "pnpm --filter website build",
    "docs:serve": "pnpm --filter website serve",
    "cli:build": "pnpm --filter @weavster/core build && pnpm --filter @weavster/cli build",
    "cli:link": "pnpm cli:build && cd cli && pnpm link --global",
    "test": "pnpm -r test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "biome lint --write --no-errors-on-unmatched",
      "prettier --write"
    ],
    "*.{json,jsonc,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.3.3"
  }
}
