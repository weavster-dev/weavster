{
  "name": "@weavster/cli",
  "version": "0.0.1",
  "description": "Weavster CLI: scaffold, validate, and test config-driven data transformation projects.",
  "license": "BUSL-1.1",
  "type": "module",
  "bin": {
    "weavster": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/weavster-dev/weavster.git",
    "directory": "cli"
  },
  "homepage": "https://docs.weavster.dev",
  "keywords": [
    "weavster",
    "etl",
    "transform",
    "json",
    "xml",
    "integration",
    "cli"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "validate": "tsx src/index.ts validate",
    "test": "vitest run",
    "prepublishOnly": "tsup"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "commander": "^13.1.0",
    "fast-xml-parser": "^5.8.0",
    "jiti": "^2.7.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@weavster/core": "workspace:*",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.8"
  }
}
